# Gmail OAuth credentials for Autopilot.
# Put real values in .env.local. Do not commit .env.local.
AUTOPILOT_GOOGLE_CLIENT_ID=
# Optional for local development only. Do not bundle or commit real secrets.
AUTOPILOT_GOOGLE_CLIENT_SECRET=
# Add this redirect URI to Web application OAuth clients:
# http://127.0.0.1:53682/oauth/gmail/callback
AUTOPILOT_GOOGLE_REDIRECT_PORT=53682

# Supabase public account/project config.
# The URL is safe to ship in the generated public config; never put a service role key here.
AUTOPILOT_SUPABASE_PROJECT_REF=ctvxwmmclsfxortzmkeq
AUTOPILOT_SUPABASE_URL=https://ctvxwmmclsfxortzmkeq.supabase.co
AUTOPILOT_SUPABASE_ANON_KEY=

# Production safety knobs. Defaults are conservative for large rollouts.
AUTOPILOT_GMAIL_REQUEST_TIMEOUT_MS=15000
AUTOPILOT_GMAIL_RETRY_ATTEMPTS=2
AUTOPILOT_GMAIL_MESSAGE_CONCURRENCY=4

# OpenAI is used by the Electron main process to turn synced emails into Today's Call action items.
# Put the real key in .env.local. Never expose this key in public/autopilot-config.json.
AUTOPILOT_OPENAI_API_KEY=
AUTOPILOT_OPENAI_MODEL=gpt-4o-mini
AUTOPILOT_OPENAI_BASE_URL=https://api.openai.com/v1
AUTOPILOT_OPENAI_REQUEST_TIMEOUT_MS=30000
