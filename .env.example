# Gmail OAuth credentials for Autopilot.
# Put real values in .env.local. Do not commit .env.local.
AUTOPILOT_GOOGLE_CLIENT_ID=
# Optional for local development only. Do not bundle or commit real secrets.
AUTOPILOT_GOOGLE_CLIENT_SECRET=
# Add this redirect URI to Web application OAuth clients:
# http://127.0.0.1:53682/oauth/gmail/callback
AUTOPILOT_GOOGLE_REDIRECT_PORT=53682

# Supabase public account/project config.
# The URL is safe to ship in the generated public config; never put a service role key here.
AUTOPILOT_SUPABASE_PROJECT_REF=ctvxwmmclsfxortzmkeq
AUTOPILOT_SUPABASE_URL=https://ctvxwmmclsfxortzmkeq.supabase.co
AUTOPILOT_SUPABASE_ANON_KEY=
# Standard deploy aliases are also supported: SUPABASE_URL and SUPABASE_ANON_KEY.

# Production AI access. Ship this public URL in public/autopilot-config.json.
# The proxy must store OPENAI_API_KEY server-side; never ship that key in the desktop app.
AUTOPILOT_AI_PROXY_URL=
AUTOPILOT_AI_ARTIFACT_URL=
AUTOPILOT_AI_EMAIL_ACTIONS_URL=

# Supabase Edge payment verification sends through Resend when these are set as Supabase secrets.
# If Resend is absent, the payments-verification function falls back to a Supabase Auth email link.
# Do not put RESEND_API_KEY or Stripe secret keys in the packaged desktop app.
# PAYMENTS_VERIFICATION_REDIRECT_URL should usually be autopilot://auth/callback in Supabase secrets.

# Production safety knobs. Defaults are conservative for large rollouts.
AUTOPILOT_GMAIL_REQUEST_TIMEOUT_MS=15000
AUTOPILOT_GMAIL_RETRY_ATTEMPTS=2
AUTOPILOT_GMAIL_MESSAGE_CONCURRENCY=4

# Local development fallback only. Downloaded users should use AUTOPILOT_AI_PROXY_URL plus Supabase sign-in.
# Never expose this key in public/autopilot-config.json or a packaged app.
AUTOPILOT_OPENAI_API_KEY=
AUTOPILOT_OPENAI_MODEL=gpt-5.5
# Optional cost routing. Leave blank to fall back to AUTOPILOT_OPENAI_MODEL.
# Use cheaper models for high-volume triage/critique/prompt ideas and keep frontier for visible final quality.
AUTOPILOT_OPENAI_MODEL_NANO=
AUTOPILOT_OPENAI_MODEL_MINI=
AUTOPILOT_OPENAI_MODEL_STANDARD=
AUTOPILOT_OPENAI_MODEL_FRONTIER=
AUTOPILOT_OPENAI_BASE_URL=https://api.openai.com/v1
AUTOPILOT_OPENAI_REQUEST_TIMEOUT_MS=30000
