{
  "name": "autopilot",
  "version": "0.1.0",
  "description": "Autopilot, a Chromium-based browser workspace.",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.electron.json",
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:main && vite build",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "check": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "autopilot",
    "browser",
    "electron",
    "chromium"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.7",
    "vitest": "^4.0.15",
    "wait-on": "^8.0.1"
  }
}
