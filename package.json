{
  "name": "autopilot",
  "version": "0.1.0",
  "description": "Autopilot Browser, an AI-powered Chromium workspace.",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "configure:gmail": "node scripts/generate-app-config.mjs",
    "build:main": "tsc -p tsconfig.electron.json",
    "dev": "npm run build:main && npm run configure:gmail && concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:main && npm run configure:gmail && vite build",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test -c playwright.config.ts",
    "check": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "autopilot",
    "browser",
    "electron",
    "chromium"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "build": {
    "appId": "com.autopilot.browser",
    "productName": "Autopilot Browser",
    "artifactName": "Autopilot-Browser-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/autopilot-logo.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Autopilot Browser"
    }
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.7",
    "vitest": "^4.0.15",
    "wait-on": "^8.0.1"
  }
}
